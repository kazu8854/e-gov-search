{
  "name": "e-gov-search",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "package": "bash scripts/package-lambda.sh",
    "cdk:deploy": "npm run package && cd cdk && npm install && npx cdk deploy --require-approval never",
    "cdk:destroy": "cd cdk && npx cdk destroy --force",
    "build:static": "STATIC_EXPORT=true next build"
  },
  "dependencies": {
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "openai": "^4.103.0",
    "lucide-react": "^0.511.0",
    "@aws-sdk/client-secrets-manager": "^3.800.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.3",
    "typescript": "^5.8.0",
    "tailwindcss": "^4.1.0",
    "@tailwindcss/postcss": "^4.1.0",
    "postcss": "^8.5.0"
  }
}